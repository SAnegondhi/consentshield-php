{
    "name": "consentshield/php",
    "type": "library",
    "version": "1.0.0",
    "description": "Compliance-contract wrapper around the ConsentShield generated PHP client, adding retry-aware Guzzle middleware, fail-CLOSED defaults, and a typed exception hierarchy. Laravel and Symfony examples included.",
    "keywords": ["consentshield", "dpdp", "consent", "compliance", "sdk"],
    "homepage": "https://github.com/consentshield-org/php",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Sudhindra Anegondhi",
            "email": "a.d.sudhindra@gmail.com",
            "homepage": "https://consentshield.in"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "consentshield/consentshield": "1.0.0",
        "guzzlehttp/guzzle": "^7.0",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/log": "^1.0 || ^2.0 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "guzzlehttp/psr7": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "ConsentShield\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ConsentShield\\Sdk\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../generated",
            "options": { "symlink": true }
        }
    ],
    "minimum-stability": "stable"
}
