{
  "name": "@consentshield/node",
  "version": "1.0.0",
  "description": "Official Node.js client for the ConsentShield DPDP compliance API. Fail-closed by default; 2-second request timeout; trace-id correlated.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": "Sudhindra Anegondhi <a.d.sudhindra@gmail.com>",
  "homepage": "https://consentshield.in/docs",
  "repository": {
    "type": "git",
    "url": "https://github.com/aiSpirit-systems/consentshield.git",
    "directory": "packages/node-client"
  },
  "bugs": {
    "url": "https://github.com/aiSpirit-systems/consentshield/issues"
  },
  "keywords": [
    "consentshield",
    "dpdp",
    "consent",
    "compliance",
    "india",
    "data-privacy",
    "audit"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": ["dist", "README.md", "LICENSE.md"],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build && bun run typecheck && bun run test"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "20.19.39",
    "@vitest/coverage-v8": "4.1.4",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  }
}
