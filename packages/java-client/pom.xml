<?xml version="1.0" encoding="UTF-8"?>
<!--
  ADR-1028 Phase 1 Sprint 1.2 — top-level aggregator for the Java SDK.

  Two modules:
    - generated/  — produced by openapi-generator from app/public/openapi.yaml.
                    Maven coordinate: com.consentshield:consentshield-java:1.0.0.
                    Regenerated by `bun run generate:tier2-sdks`; do NOT hand-edit.
    - wrapper/    — hand-written Spring Boot starter + compliance-contract layer.
                    Maven coordinate: com.consentshield:consentshield-java-spring-boot-starter:1.0.0.
                    Depends on the generated client.

  Java callers without Spring use the generated artifact directly. Spring Boot
  callers add the starter and let `@AutoConfiguration` wire `ConsentShieldClient`
  as a bean. Spring deps in the starter are <optional>true</optional> so they
  don't bleed into non-Spring classpaths via transitive resolution.
-->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.consentshield</groupId>
    <artifactId>consentshield-java-parent</artifactId>
    <version>1.0.0</version>
    <packaging>pom</packaging>

    <name>ConsentShield Java SDK (parent)</name>
    <description>Aggregator for the generated client and the Spring Boot starter.</description>
    <url>https://github.com/SAnegondhi/consentshield-java</url>

    <licenses>
        <license>
            <name>Apache-2.0</name>
            <url>https://www.apache.org/licenses/LICENSE-2.0</url>
        </license>
    </licenses>

    <developers>
        <developer>
            <name>Sudhindra Anegondhi</name>
            <email>a.d.sudhindra@gmail.com</email>
            <organization>ConsentShield</organization>
            <organizationUrl>https://consentshield.in</organizationUrl>
        </developer>
    </developers>

    <scm>
        <connection>scm:git:git://github.com/SAnegondhi/consentshield-java.git</connection>
        <developerConnection>scm:git:git@github.com:SAnegondhi/consentshield-java.git</developerConnection>
        <url>https://github.com/SAnegondhi/consentshield-java</url>
    </scm>

    <modules>
        <module>generated</module>
        <module>wrapper</module>
    </modules>

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <maven.compiler.source>11</maven.compiler.source>
        <maven.compiler.target>11</maven.compiler.target>
    </properties>
</project>
